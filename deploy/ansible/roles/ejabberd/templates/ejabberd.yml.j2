###
### KewlChats ejabberd config — PRODUCTION (managed by Ansible).
###
### Deltas from the dev source (ops/ejabberd/ejabberd.yml):
###   - MULTI-VHOST: one node serves every site domain; vhosts route to each
###     other internally (no s2s). Each vhost has its own admin + LE cert.
###   - NO IPv6: c2s on 0.0.0.0, HTTP API on 127.0.0.1 only, 5443 dropped
###   - MySQL backend (new schema), shared by all vhosts
###   - MAM ON, full retention (archive kept; no trim timer)
###   - HTTP File Upload (XEP-0363): mod_http_upload + quota (25 MiB/file, 30-day expiry)
###   - s2s: allowlisted to push gateways only (XEP-0357 push), both directions; 5269 gated by s2s_access
###   - MUC: ONE shared service ({{ xmpp_muc_domain }}) via append_host_config, not per-vhost conference.*
###   - Let's Encrypt certs (shared with nginx; wildcards cover conference/pubsub)
###   - TURN advertises the server's public IPv4
###

hosts:
{% for s in sites %}
  - {{ s.domain }}
{% endfor %}

loglevel: info

# Accounts live in MySQL (not Mnesia). auth_method is independent of default_db:
# without this, default_db:sql would still leave authentication on internal/Mnesia.
auth_method: sql

certfiles:
{% for cn in ejabberd_cert_names %}
  - {{ ejabberd_certs_dir }}/{{ cn }}.pem
{% endfor %}

## We manage TLS ourselves (certbot DNS-01 → the certfiles above). Disable
## ejabberd's built-in ACME or it would try to issue its own certs via HTTP-01 on
## port 80, fighting nginx. (auto is ON by default.) Renewal stays certbot's job.
acme:
  auto: false

## --- s2s: allowlisted to push gateways ONLY (mobile push needs it; NOT federation) ---
## XEP-0357 push is delivered over s2s to the apps' push app-servers
## (Monal: *.prod.push.monal-im.org). BOTH directions are enabled — the appserver answers
## via a reverse/dialback connection, so a restricted INBOUND 5269 listener is needed too.
## s2s_access (s2s_push) permits s2s ONLY to/from the push_servers ACL, so every other
## server is rejected at the stream layer — general federation stays off.
s2s_use_starttls: required
s2s_access: s2s_push
ca_file: /etc/ssl/certs/ca-certificates.crt   # verify push-gateway certs on s2s

## OAuth: Laravel mints short-lived X-OAUTH2 tokens for web chat and authenticates
## the ReST API with a bearer token.
oauth_access: all
oauth_expire: 31536000

## --- SQL backend (MySQL, new schema) ---
default_db: sql
sql_type: mysql
sql_server: "127.0.0.1"
sql_port: 3306
sql_database: "{{ mysql_ejabberd_db }}"
sql_username: "{{ mysql_ejabberd_user }}"
sql_password: "{{ db_ejabberd_password }}"
new_sql_schema: true
# ejabberd creates/updates the SQL tables itself on startup (default true since
# 24.06) — no manual `mysql.new.sql` import needed.
update_sql_schema: true
sql_pool_size: 8

listen:
  -
    port: 5222
    ip: "0.0.0.0"
    module: ejabberd_c2s
    max_stanza_size: 262144
    shaper: c2s_shaper
    access: c2s
    starttls_required: true
  -
    ## Direct TLS c2s (XEP-0368) — implicit TLS on connect, no STARTTLS. Monal prefers
    ## this; advertise it via the _xmpps-client._tcp SRV record (port 5223).
    port: 5223
    ip: "0.0.0.0"
    module: ejabberd_c2s
    tls: true
    max_stanza_size: 262144
    shaper: c2s_shaper
    access: c2s
  -
    ## Plain HTTP on loopback ONLY — Laravel ReST calls + the nginx-proxied
    ## WebSocket/BOSH land here. Never exposed publicly (nginx terminates TLS).
    port: 5280
    ip: "127.0.0.1"
    module: ejabberd_http
    request_handlers:
      /admin: ejabberd_web_admin
      /api: mod_http_api
      /bosh: mod_bosh
      /ws: ejabberd_http_ws
      /upload: mod_http_upload    # XEP-0363 (nginx proxies https://<domain>/upload here)
  -
    ## Built-in STUN/TURN for Jingle voice/video (no coturn).
    port: 5478
    transport: udp
    module: ejabberd_stun
    use_turn: true
    turn_ipv4_address: "{{ turn_public_ipv4_effective }}"
    turn_min_port: {{ turn_min_port }}
    turn_max_port: {{ turn_max_port }}
  -
    ## Inbound s2s — restricted to the push gateways by s2s_access (s2s_push). The port
    ## is open, but ejabberd rejects every non-allowlisted remote at the stream layer,
    ## so this is push delivery, NOT open federation.
    port: 5269
    ip: "0.0.0.0"
    module: ejabberd_s2s_in

## --- s2s is allowlisted to the push gateways only (see s2s_access / push_servers ACL)
## for XEP-0357 mobile push — both directions, no general federation. ---

acl:
  local:
    user_regexp: ""
  loopback:
    ip:
      - 127.0.0.0/8
  admin:
    user:
{% for s in sites %}
      - "admin@{{ s.domain }}"
{% endfor %}
  push_servers:
    server:
{% for d in s2s_push_domains %}
      - {{ d }}
{% endfor %}

access_rules:
  local:
    allow: local
  c2s:
    deny: blocked
    allow: all
  announce:
    allow: admin
  configure:
    allow: admin
  muc_create:
    allow: local
  pubsub_createnode:
    allow: local
  trusted_network:
    allow: loopback
  # s2s permitted only to the push gateways (everything else denied = walled garden).
  s2s_push:
    allow: push_servers
    deny: all

api_permissions:
  "console commands":
    from: ejabberd_ctl
    who: all
    what: "*"
  "webadmin commands":
    from: ejabberd_web_admin
    who: admin
    what: "*"
  "http api":
    from: mod_http_api
    who:
      access:
        allow:
          - acl: loopback
          - acl: admin
      oauth:
        scope: "ejabberd:admin"
        access:
          allow:
            - acl: loopback
            - acl: admin
    what:
      - "*"
      - "!stop"
      - "!start"

shaper:
  normal:
    rate: 3000
    burst_size: 20000
  fast: 100000

shaper_rules:
  max_user_sessions: 10
  max_user_offline_messages:
    100: all
  c2s_shaper:
    none: admin
    normal: all
  # Per-user HTTP-upload quotas (MiB) — read by mod_http_upload_quota.
  soft_upload_quota:
    {{ upload_soft_quota_mb }}: all
  hard_upload_quota:
    {{ upload_hard_quota_mb }}: all

modules:
  mod_adhoc: {}
  mod_adhoc_api: {}
  mod_admin_extra: {}
  mod_announce:
    access: announce
  mod_avatar: {}
  mod_blocking: {}
  mod_bosh: {}
  mod_caps: {}
  mod_carboncopy: {}        # Carbons ON — live multi-device
  mod_client_state: {}
  mod_configure: {}
  mod_disco: {}
  mod_fail2ban: {}
  mod_http_api: {}
  mod_http_upload:          # XEP-0363: share images/files (Monal/Conversations/web)
    # Service JID upload.@HOST@ per vhost; the HTTP endpoint is the loopback :5280
    # listener, which nginx exposes as https://<domain>/upload. @HOST@ resolves to
    # each vhost, so every site hands out its own URL.
    host: "upload.@HOST@"
    name: "File Upload"
    docroot: "{{ ejabberd_upload_dir }}"
    put_url: "https://@HOST@/upload"
    get_url: "https://@HOST@/upload"
    max_size: {{ upload_max_size }}   # per-file cap (bytes)
    thumbnail: false        # skip server-side thumbnails (avoids the ImageMagick/eimp dep)
    file_mode: "0640"
    dir_mode: "0750"
    # OMEMO media (aesgcm://) and cross-site viewing fetch over XHR — allow CORS so
    # web chat can decrypt/display media hosted on the other vhost's domain.
    custom_headers:
      "Access-Control-Allow-Origin": "*"
      "Access-Control-Allow-Methods": "GET,HEAD,PUT,OPTIONS"
      "Access-Control-Allow-Headers": "Content-Type"
  mod_http_upload_quota:    # cap per-user storage + expire old files (storage/privacy lever)
    max_days: {{ upload_max_days }}
  mod_last: {}              # backs get_last -> lastActivity()
  mod_mam:                  # MAM ON: full server-side archive (no retention trim)
    db_type: sql
    default: always
    user_mucsub_from_muc_archive: true
  ## mod_muc / mod_muc_admin are NOT loaded globally — a single shared MUC service
  ## runs on one vhost only (see append_host_config at the bottom), so conference.<vhost>
  ## is never auto-created per site. Other vhosts discover it via mod_disco.
  mod_offline:              # short-lived spool: delivered once, then gone
    access_max_user_messages: max_user_offline_messages
  mod_ping: {}
  mod_privacy: {}
  mod_private: {}
  mod_pubsub:
    access_createnode: pubsub_createnode
    plugins:
      - flat
      - pep
    force_node_config:
      storage:bookmarks:
        access_model: whitelist
  mod_push: {}
  mod_push_keepalive: {}
  mod_register:
    ## In-band registration DENIED — the website is the only way in.
    access: none
  mod_roster:
    versioning: true
  mod_shared_roster: {}
  mod_s2s_dialback: {}      # allow dialback auth on the (allowlisted) push s2s connections
  mod_stream_mgmt:
    resend_on_timeout: if_offline
  mod_stun_disco: {}        # advertises the built-in STUN/TURN (XEP-0215)
  mod_vcard: {}
  mod_vcard_xupdate: {}
  mod_version:
    show_os: false

## --- Per-vhost overrides ---------------------------------------------------------
## Shared MUC: ejabberd's mod_muc is per-vhost and would otherwise spin up
## conference.<vhost> for EVERY site (so a kewlchats.net user's client finds
## conference.kewlchats.net). We want ONE community room host ({{ xmpp_muc_domain }}),
## so mod_muc runs only on its owning vhost ({{ muc_vhost }}); every other vhost
## advertises it through mod_disco extra_domains so their clients still discover it.
## Cross-vhost joins route internally (no s2s).
##
## MUST be append_host_config, NOT host_config: host_config REPLACES a vhost's ENTIRE
## module list (dropping mod_admin_extra/mod_mam/mod_roster/mod_register/… and breaking
## the ReST API + archiving); append_host_config MERGES these onto the global modules.
append_host_config:
  {{ muc_vhost }}:
    modules:
      mod_muc:
        hosts:
          - {{ xmpp_muc_domain }}
        access:
          - allow
        access_admin:
          - allow: admin
        access_create: muc_create
        access_persistent: muc_create
        history_size: 20            # recent scrollback for joiners
        default_room_options:
          mam: true                 # archive MUC messages (kept — no trim)
      mod_muc_admin: {}
{% for s in sites if s.domain != muc_vhost %}
  {{ s.domain }}:
    modules:
      mod_disco:
        extra_domains:
          - {{ xmpp_muc_domain }}   # surface the shared MUC to this vhost's clients
{% endfor %}
