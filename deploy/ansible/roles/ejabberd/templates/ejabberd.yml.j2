###
### KewlChats ejabberd config — PRODUCTION (managed by Ansible).
###
### Deltas from the dev source (ops/ejabberd/ejabberd.yml):
###   - MULTI-VHOST: one node serves every site domain; vhosts route to each
###     other internally (no s2s). Each vhost has its own admin + LE cert.
###   - NO IPv6: c2s on 0.0.0.0, HTTP API on 127.0.0.1 only, 5443 dropped
###   - MySQL backend (new schema), shared by all vhosts
###   - MAM ON, {{ mam_retention_days }}-day retention (trimmed by a daily timer)
###   - Let's Encrypt certs (shared with nginx; wildcards cover conference/pubsub)
###   - TURN advertises the server's public IPv4
###

hosts:
{% for s in sites %}
  - {{ s.domain }}
{% endfor %}

loglevel: info

auth_method: internal

certfiles:
{% for cn in ejabberd_cert_names %}
  - {{ ejabberd_certs_dir }}/{{ cn }}.pem
{% endfor %}

## OAuth: Laravel mints short-lived X-OAUTH2 tokens for web chat and authenticates
## the ReST API with a bearer token.
oauth_access: all
oauth_expire: 31536000

## --- SQL backend (MySQL, new schema) ---
default_db: sql
sql_type: mysql
sql_server: "127.0.0.1"
sql_port: 3306
sql_database: "{{ mysql_ejabberd_db }}"
sql_username: "{{ mysql_ejabberd_user }}"
sql_password: "{{ db_ejabberd_password }}"
new_sql_schema: true
sql_pool_size: 8

listen:
  -
    port: 5222
    ip: "0.0.0.0"
    module: ejabberd_c2s
    max_stanza_size: 262144
    shaper: c2s_shaper
    access: c2s
    starttls_required: true
  -
    ## Plain HTTP on loopback ONLY — Laravel ReST calls + the nginx-proxied
    ## WebSocket/BOSH land here. Never exposed publicly (nginx terminates TLS).
    port: 5280
    ip: "127.0.0.1"
    module: ejabberd_http
    request_handlers:
      /admin: ejabberd_web_admin
      /api: mod_http_api
      /bosh: mod_bosh
      /ws: ejabberd_http_ws
      /.well-known/acme-challenge: ejabberd_acme
  -
    ## Built-in STUN/TURN for Jingle voice/video (no coturn).
    port: 5478
    transport: udp
    module: ejabberd_stun
    use_turn: true
    turn_ipv4_address: "{{ turn_public_ipv4_effective }}"
    turn_min_port: {{ turn_min_port }}
    turn_max_port: {{ turn_max_port }}

## --- Federation OFF: no 5269 s2s listener, no s2s modules. ---

acl:
  local:
    user_regexp: ""
  loopback:
    ip:
      - 127.0.0.0/8
  admin:
    user:
{% for s in sites %}
      - "admin@{{ s.domain }}"
{% endfor %}

access_rules:
  local:
    allow: local
  c2s:
    deny: blocked
    allow: all
  announce:
    allow: admin
  configure:
    allow: admin
  muc_create:
    allow: local
  pubsub_createnode:
    allow: local
  trusted_network:
    allow: loopback

api_permissions:
  "console commands":
    from: ejabberd_ctl
    who: all
    what: "*"
  "webadmin commands":
    from: ejabberd_web_admin
    who: admin
    what: "*"
  "http api":
    from: mod_http_api
    who:
      access:
        allow:
          - acl: loopback
          - acl: admin
      oauth:
        scope: "ejabberd:admin"
        access:
          allow:
            - acl: loopback
            - acl: admin
    what:
      - "*"
      - "!stop"
      - "!start"

shaper:
  normal:
    rate: 3000
    burst_size: 20000
  fast: 100000

shaper_rules:
  max_user_sessions: 10
  max_user_offline_messages:
    100: all
  c2s_shaper:
    none: admin
    normal: all

modules:
  mod_adhoc: {}
  mod_adhoc_api: {}
  mod_admin_extra: {}
  mod_announce:
    access: announce
  mod_avatar: {}
  mod_blocking: {}
  mod_bosh: {}
  mod_caps: {}
  mod_carboncopy: {}        # Carbons ON — live multi-device
  mod_client_state: {}
  mod_configure: {}
  mod_disco: {}
  mod_fail2ban: {}
  mod_http_api: {}
  mod_last: {}              # backs get_last -> lastActivity()
  mod_mam:                  # MAM ON: short server-side archive (trimmed to {{ mam_retention_days }} days)
    db_type: sql
    default: always
    user_mucsub_from_muc_archive: true
  mod_muc:
    access:
      - allow
    access_admin:
      - allow: admin
    access_create: muc_create
    access_persistent: muc_create
    history_size: 20        # recent scrollback for joiners
    default_room_options:
      mam: true             # archive MUC messages (trimmed with everything else)
  mod_muc_admin: {}
  mod_offline:              # short-lived spool: delivered once, then gone
    access_max_user_messages: max_user_offline_messages
  mod_ping: {}
  mod_privacy: {}
  mod_private: {}
  mod_pubsub:
    access_createnode: pubsub_createnode
    plugins:
      - flat
      - pep
    force_node_config:
      storage:bookmarks:
        access_model: whitelist
  mod_push: {}
  mod_push_keepalive: {}
  mod_register:
    ## In-band registration DENIED — the website is the only way in.
    access: none
  mod_roster:
    versioning: true
  mod_shared_roster: {}
  mod_stream_mgmt:
    resend_on_timeout: if_offline
  mod_stun_disco: {}        # advertises the built-in STUN/TURN (XEP-0215)
  mod_vcard: {}
  mod_vcard_xupdate: {}
  mod_version:
    show_os: false
