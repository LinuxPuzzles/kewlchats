[Unit]
Description=KewlChats XMPP reconcile ({{ site.name }})
After=network.target ejabberd.service

[Service]
Type=oneshot
User={{ site.name }}
Group={{ site.name }}
WorkingDirectory={{ app_root }}/{{ site.name }}
ExecStart=/usr/bin/php{{ php_version }} {{ app_root }}/{{ site.name }}/artisan kewlchats:reconcile
