; Managed by Ansible (kewlchats) — PHP-FPM pool for the {{ app_name }} app (all front doors).
; Children run as the {{ app_name }} user; nginx ({{ web_user }}) connects via the socket
; below, which is owned by {{ web_user }} so only nginx (and root) can reach it.
[{{ app_name }}]
user = {{ app_name }}
group = {{ app_name }}

listen = /run/php/{{ app_name }}.sock
listen.owner = {{ web_user }}
listen.group = {{ web_group }}
listen.mode = 0660

pm = {{ php_fpm_pm }}
pm.max_children = {{ php_fpm_max_children }}
pm.start_servers = {{ php_fpm_start_servers }}
pm.min_spare_servers = {{ php_fpm_min_spare }}
pm.max_spare_servers = {{ php_fpm_max_spare }}
pm.max_requests = {{ php_fpm_max_requests }}

; memory_limit/opcache come from the global 99-kewlchats.ini drop-in (all pools);
; restated here only so per-pool tuning has an obvious home.
php_admin_value[memory_limit] = {{ php_memory_limit }}
catch_workers_output = yes
