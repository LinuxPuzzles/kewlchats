APP_NAME="{{ site.brand }}"
APP_ENV=production
APP_KEY={{ lookup('vars', 'app_key_' ~ site.name) }}
APP_DEBUG=false
APP_URL=https://{{ site.domain }}
# Selects the Blade theme (resources/views/themes/<theme>); empty dir = base look.
SITE_THEME={{ site.theme }}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE={{ site.name }}
DB_USERNAME={{ site.name }}
DB_PASSWORD={{ lookup('vars', 'db_password_' ~ site.name) }}

# Redis backs queue + cache + sessions. Per-site key prefix keeps the shared
# instance's namespaces separate.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD={{ redis_password }}
REDIS_PORT=6379
REDIS_PREFIX={{ site.name }}_

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX={{ site.name }}_

# Postmark SMTP — the server token is BOTH the username and the password.
# (The site's from-domain must be a verified sender in Postmark.)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST={{ mail_host }}
MAIL_PORT={{ mail_port }}
MAIL_USERNAME={{ postmark_token }}
MAIL_PASSWORD={{ postmark_token }}
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="{{ site.mail_from }}"
MAIL_FROM_NAME="{{ site.brand }}"
MAIL_THEME={{ site.mail_theme | default('default') }}

VITE_APP_NAME="${APP_NAME}"

# XMPP / ejabberd integration. This site's vhost on the shared ejabberd node.
XMPP_DRIVER=ejabberd
XMPP_DOMAIN={{ site.domain }}
# Shared across all sites (identity is per-domain; the room space is one community).
XMPP_MUC_DOMAIN={{ xmpp_muc_domain }}
XMPP_API_BASE=http://127.0.0.1:5280/api
XMPP_API_TOKEN={{ lookup('vars', 'xmpp_api_token_' ~ site.name) }}
XMPP_WEBSOCKET_URL=wss://{{ site.domain }}/ws
XMPP_BOSH_URL=https://{{ site.domain }}/bosh
# Shared across all sites (same value everywhere) — both front doors land in one lounge.
XMPP_LANDING_ROOM={{ xmpp_landing_room }}

# Unbotable — privacy-respecting bot protection (central service; no key needed).
UNBOTABLE_URL=https://unbotable.com
