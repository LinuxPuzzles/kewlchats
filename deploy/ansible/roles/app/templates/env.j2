{% set primary = sites | selectattr('domain', 'equalto', primary_domain) | first %}
# ONE install serves every front door. These are boot/fallback defaults (the primary
# door); the ResolveSite middleware overrides brand/theme/domain/mail per request from
# the Host (config/sites.php), and mail picks the recipient's door at send time.
APP_NAME="{{ primary.brand }}"
APP_ENV=production
APP_KEY={{ lookup('vars', 'app_key_' ~ app_name) }}
APP_DEBUG=false
APP_URL=https://{{ primary_domain }}
SITE_PRIMARY_DOMAIN={{ primary_domain }}
# Boot-default theme; per-request theme comes from the Host via ResolveSite.
SITE_THEME={{ primary.theme }}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# One shared application database for the whole community (single source of truth).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE={{ app_name }}
DB_USERNAME={{ app_name }}
DB_PASSWORD={{ lookup('vars', 'db_password_' ~ app_name) }}

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD={{ redis_password }}
REDIS_PORT=6379
REDIS_PREFIX={{ app_name }}_

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX={{ app_name }}_

# Postmark SMTP — the server token is BOTH the username and the password.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST={{ mail_host }}
MAIL_PORT={{ mail_port }}
MAIL_USERNAME={{ postmark_token }}
MAIL_PASSWORD={{ postmark_token }}
MAIL_ENCRYPTION=tls
# Boot/fallback brand+theme; per-recipient values are applied by SiteContext at send.
MAIL_FROM_ADDRESS="{{ primary.mail_from }}"
MAIL_FROM_NAME="{{ primary.brand }}"
MAIL_THEME={{ primary.mail_theme | default('default') }}

VITE_APP_NAME="${APP_NAME}"

# XMPP / ejabberd. One install, multiple vhosts on the shared node; a user's vhost
# comes from their users.domain row, not these defaults.
XMPP_DRIVER=ejabberd
XMPP_DOMAIN={{ primary_domain }}
# Every front-door domain sharing ONE username namespace (community-wide uniqueness).
XMPP_COMMUNITY_DOMAINS={{ sites | map(attribute='domain') | join(',') }}
# Shared MUC host for the whole community.
XMPP_MUC_DOMAIN={{ xmpp_muc_domain }}
XMPP_API_BASE=http://127.0.0.1:5280/api
# Loopback grants node-admin across vhosts, so the primary vhost's token covers all.
XMPP_API_TOKEN={{ lookup('vars', 'xmpp_api_token_' ~ app_name) }}
XMPP_WEBSOCKET_URL=wss://{{ primary_domain }}/ws
XMPP_BOSH_URL=https://{{ primary_domain }}/bosh
XMPP_LANDING_ROOM={{ xmpp_landing_room }}

# Unbotable — privacy-respecting bot protection (central service; no key needed).
UNBOTABLE_URL=https://unbotable.com
